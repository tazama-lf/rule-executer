{
  "name": "rule-executer",
  "version": "1.2.0",
  "description": "Actio FRM Rule Executer",
  "main": "build/index.js",
  "types": "build/index.d.ts",
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "start": "node -r dotenv/config build/index.js",
    "clean": "npx rimraf build node_modules coverage package-lock.json",
    "fix": "npm run fix:prettier && npm run fix:eslint",
    "fix:eslint": "eslint --fix",
    "fix:prettier": "prettier --write \"**/*.ts\"",
    "lint": "npm run lint:eslint && npm run lint:prettier",
    "lint:eslint": "eslint",
    "lint:eslint-unused": "eslint --report-unused-disable-directives",
    "lint:eslint-no-inline": "eslint --no-inline-config",
    "lint:prettier": "prettier --check \"**/*.ts\"",
    "cleanup": "rm -rf build template jest.config.js jest.config.js.map node_modules package-lock.json",
    "prepare": "husky",
    "test": "set STARTUP_TYPE=nats&&jest --config=jest.config.ts --passWithNoTests --runInBand --detectOpenHandles --forceExit",
    "test:watch": "jest --config=jest.config.ts --watch"
  },
  "keywords": [],
  "license": "Apache-2.0",
  "dependencies": {
    "@tazama-lf/frms-coe-lib": "5.0.0",
    "@tazama-lf/frms-coe-startup-lib": "2.3.0",
    "dotenv": "^17.1.0",
    "node-cache": "^5.1.2",
    "rule": "npm:@tazama-lf/rule-901@2.1.0",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@eslint-community/eslint-plugin-eslint-comments": "^4.5.0",
    "@stylistic/eslint-plugin": "^5.1.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.0.12",
    "@typescript-eslint/eslint-plugin": "^8.36.0",
    "@typescript-eslint/parser": "^8.36.0",
    "eslint": "^9.30.1",
    "eslint-config-love": "^121.0.0",
    "eslint-config-prettier": "^10.1.5",
    "husky": "9.1.7",
    "ioredis-mock": "^8.9.0",
    "jest": "^30.0.4",
    "lint-staged": "^16.1.2",
    "prettier": "^3.6.2",
    "ts-jest": "^29.4.0",
    "typescript": "^5.8.3"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix",
      "prettier --write"
    ]
  }
}
